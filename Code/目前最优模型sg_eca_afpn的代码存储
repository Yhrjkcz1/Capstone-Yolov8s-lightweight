class ASFF_2L(nn.Module):
    def __init__(self, c1, c2, level=0):
        super(ASFF_2L, self).__init__()
        self.inter_dim = int(c2)
        
        # 严格对齐你 YAML 传入的通道
        self.adapter0 = nn.Conv2d(c1[0], self.inter_dim, 1) if c1[0] != self.inter_dim else nn.Identity()
        self.adapter1 = nn.Conv2d(c1[1], self.inter_dim, 1) if c1[1] != self.inter_dim else nn.Identity()
        
        # 改进：权值计算增加全局感知。输入是 inter_dim，输出是 2 通道
        # 使用 1x1 卷积组合，不改变特征图尺寸，不增加参数负担
        self.gap = nn.AdaptiveAvgPool2d(1)
        self.weight_gen = nn.Sequential(
            nn.Conv2d(self.inter_dim, self.inter_dim // 4, 1, bias=False),
            nn.ReLU(inplace=True),
            nn.Conv2d(self.inter_dim // 4, 2, 1, bias=False) 
        )
        
        self.softmax = nn.Softmax(dim=1)
        self.expand = Conv(self.inter_dim, self.inter_dim, 3, 1)

    def forward(self, x):
        x0 = self.adapter0(x[0])
        x1 = self.adapter1(x[1])
        
        # 核心逻辑：利用全局 + 局部信息生成权重
        # 1x1 卷积处理局部，GAP 处理全局，相加后生成最终决策
        feat_sum = x0 + x1
        global_context = self.gap(feat_sum)
        
        # 生成两个通道的权重权重图
        weights = self.weight_gen(feat_sum + global_context) 
        weights = self.softmax(weights)
        
        # 加权融合
        out = x0 * weights[:, 0:1] + x1 * weights[:, 1:2]
        return self.expand(out)
        return self.expand(out)
    
class ASFF_3L(nn.Module):
    """
    ASFF (Adaptively Spatial Feature Fusion) for 3 levels (P3, P4, P5).
    用于 AFPN 的最终三层全融合阶段。
    """
    def __init__(self, inter_dim, level):
        super(ASFF_3L, self).__init__()
        self.inter_dim = int(inter_dim)
        self.level = level
        
        self.weight_level_0 = Conv(self.inter_dim, 1, 1, 1)
        self.weight_level_1 = Conv(self.inter_dim, 1, 1, 1)
        self.weight_level_2 = Conv(self.inter_dim, 1, 1, 1)
        
        self.softmax = nn.Softmax(dim=1)
        self.expand = Conv(self.inter_dim, int(self.inter_dim), 3, 1)

    def forward(self, x):
        """
        x[0]: P3 feature
        x[1]: P4 feature
        x[2]: P5 feature
        """
        x0, x1, x2 = x
        
        w0 = self.weight_level_0(x0)
        w1 = self.weight_level_1(x1)
        w2 = self.weight_level_2(x2)
        
        weight = self.softmax(torch.cat([w0, w1, w2], dim=1))
        
        out = x0 * weight[:, 0:1, :, :] + \
              x1 * weight[:, 1:2, :, :] + \
              x2 * weight[:, 2:3, :, :]
              
        return self.expand(out)

