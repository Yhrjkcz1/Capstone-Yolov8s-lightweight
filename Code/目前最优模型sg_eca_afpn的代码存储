# Coordinate Attention (CA) for YOLOv8 C2f Integration
# =================================================================

class h_sigmoid(nn.Module):
    def __init__(self, inplace=True):
        super(h_sigmoid, self).__init__()
        self.relu = nn.ReLU6(inplace=inplace)

    def forward(self, x):
        return self.relu(x + 3) / 6

class h_swish(nn.Module):
    def __init__(self, inplace=True):
        super(h_swish, self).__init__()
        self.sigmoid = h_sigmoid(inplace=inplace)

    def forward(self, x):
        return x * self.sigmoid(x)

class CoordAtt(nn.Module):
    def __init__(self, inp, oup, reduction=32):
        super(CoordAtt, self).__init__()
        self.pool_h = nn.AdaptiveAvgPool2d((None, 1))
        self.pool_w = nn.AdaptiveAvgPool2d((1, None))

        mip = max(8, inp // reduction)

        self.conv1 = nn.Conv2d(inp, mip, kernel_size=1, stride=1, padding=0)
        self.bn1 = nn.BatchNorm2d(mip)
        self.act = h_swish()
        
        self.conv_h = nn.Conv2d(mip, oup, kernel_size=1, stride=1, padding=0)
        self.conv_w = nn.Conv2d(mip, oup, kernel_size=1, stride=1, padding=0)
        

    def forward(self, x):
        identity = x
        
        n,c,h,w = x.size()
        x_h = self.pool_h(x)
        x_w = self.pool_w(x).permute(0, 1, 3, 2)

        y = torch.cat([x_h, x_w], dim=2)
        y = self.conv1(y)
        y = self.bn1(y)
        y = self.act(y) 
        
        x_h, x_w = torch.split(y, [h, w], dim=2)
        x_w = x_w.permute(0, 1, 3, 2)

        a_h = self.conv_h(x_h).sigmoid()
        a_w = self.conv_w(x_w).sigmoid()

        out = identity * a_w * a_h

        return out

class C2f_CA(nn.Module):
    def __init__(self, c1, c2, n=1, shortcut=False, g=1, e=0.5):
        super().__init__()
        # 这里的 c1, c2, n 都是 int，我们直接用，不做任何额外缩放
        self.c = max(int(c2 * e), 1) 
        self.actual_n = int(n)
        
        self.cv1 = Conv(int(c1), 2 * self.c, 1, 1)
        self.cv2 = Conv((2 + self.actual_n) * self.c, int(c2), 1)
        
        self.m = nn.ModuleList(
            Bottleneck(self.c, self.c, shortcut, g, k=((3, 3), (3, 3)), e=1.0) 
            for _ in range(self.actual_n)
        )
        self.ca = CoordAtt(int(c2), int(c2))

    def forward(self, x):
        y = list(self.cv1(x).chunk(2, 1))
        y.extend(m(y[-1]) for m in self.m)
        out = self.cv2(torch.cat(y, 1))
        return self.ca(out)
    
# ECA module for YOLOv8 C2f Integration

class ECA(nn.Module):
    """
    Efficient Channel Attention (ECA-Net)
    自适应计算核大小：k = |(log2(c) + b) / gamma| 
    """
    def __init__(self, channel, gamma=2, b=1):
        super().__init__()
        self.avg_pool = nn.AdaptiveAvgPool2d(1)

        # 核心修正：确保输入 channel 是 int，防止 log 计算报错
        channel = int(channel)
        t = int(abs((math.log(channel, 2) + b) / gamma))
        k_size = t if t % 2 else t + 1
        k_size = max(k_size, 1)

        self.conv = nn.Conv1d(
            in_channels=1,
            out_channels=1,
            kernel_size=k_size,
            padding=(k_size - 1) // 2,
            bias=False
        )
        self.sigmoid = nn.Sigmoid()

    def forward(self, x):
        # x: [B, C, H, W]
        y = self.avg_pool(x)                     # [B, C, 1, 1]
        y = y.squeeze(-1).transpose(-1, -2)      # [B, 1, C]
        y = self.conv(y)                         # [B, 1, C]
        y = self.sigmoid(y)
        y = y.transpose(-1, -2).unsqueeze(-1)    # [B, C, 1, 1]

        return x * y.expand_as(x)

class C2f_ECA(nn.Module):
    """
    C2f 模块集成 ECA 注意力机制
    """
    def __init__(self, c1, c2, n=1, shortcut=False, g=1, e=0.5):
        super().__init__()
        # 沿用手动锁死通道的逻辑，防止 YAML 解析器导致 0 通道
        self.c = max(int(c2 * e), 1) 
        self.actual_n = int(n)
        
        self.cv1 = Conv(int(c1), 2 * self.c, 1, 1)
        self.cv2 = Conv(int((2 + self.actual_n) * self.c), int(c2), 1)
        
        self.m = nn.ModuleList(
            Bottleneck(self.c, self.c, shortcut, g, k=((3, 3), (3, 3)), e=1.0) 
            for _ in range(self.actual_n)
        )
        # 初始化 ECA
        self.eca = ECA(int(c2))

    def forward(self, x):
        y = list(self.cv1(x).chunk(2, 1))
        y.extend(m(y[-1]) for m in self.m)
        out = self.cv2(torch.cat(y, 1))
        # 在输出端进行通道注意力加权
        return self.eca(out)

# 结合 Selective Ghost 策略与 ECA 注意力机制的 C2f 模块
class C2f_SG_ECA(nn.Module):
    """
    C2f_SG_ECA: 结合了 Selective Ghost 策略与 ECA 注意力机制的特征提取模块
    旨在通过 Ghost 结构降低冗余计算，并通过 ECA 机制补偿小目标的通道特征损失。
    """
    def __init__(self, c1, c2, n=1, shortcut=False, g=1, e=0.5):
        super().__init__()
        # 强制整型化，防止 YAML 解析带来的浮点数报错
        self.c = max(int(c2 * e), 1) 
        self.actual_n = int(n)
        
        # 使用普通 Conv 进行分流，确保第一层特征提取的完整性
        self.cv1 = Conv(int(c1), 2 * self.c, 1, 1)
        self.cv2 = Conv(int((2 + self.actual_n) * self.c), int(c2), 1)
        
        # 核心改进：使用 GhostBottleneck 替换原生 Bottleneck
        # GhostBottleneck 通过廉价操作生成特征图，显著降低参数量
        self.m = nn.ModuleList(
            GhostBottleneck(self.c, self.c) 
            for _ in range(self.actual_n)
        )
        
        # 嵌套 ECA 注意力机制
        self.eca = ECA(int(c2))

    def forward(self, x):
        y = list(self.cv1(x).chunk(2, 1))
        # 经过一系列 Ghost 瓶颈层
        y.extend(m(y[-1]) for m in self.m)
        # 特征融合后，立即进行 ECA 通道加权
        out = self.cv2(torch.cat(y, 1))
        return self.eca(out)


